# ============================================
# Alex's Fitness - FRONTEND Environment Variables
# Copy to .env and fill in. DO NOT commit .env.
# ============================================
# Any VITE_* variable is inlined into the browser JS bundle at build time,
# so anyone visiting the site can read it. Only put NON-SECRET public IDs
# here. Real secrets (API tokens, signing keys, OAuth refresh tokens) live
# as Cloudflare Worker secrets — see WORKER_SECRETS.md at the repo root.

# ========== SQUARE (public IDs) ==========
# Dashboard: https://developer.squareup.com/apps

# Client-side payment form (Web Payments SDK needs the Application ID)
VITE_SQUARE_APPLICATION_ID=

# Your business location ID (find in Square Dashboard > Locations)
VITE_SQUARE_LOCATION_ID=

# Service variation IDs (one per session type)
# Get from: Square API > Catalog > list items > variation IDs
VITE_SQUARE_SERVICE_CONSULTATION=
VITE_SQUARE_SERVICE_30MIN=
VITE_SQUARE_SERVICE_60MIN=

# Optional: Square webhook subscription ID (for display/debug only)
VITE_SQUARE_WEBHOOK_ID=

# NOTE: SQUARE_ACCESS_TOKEN and SQUARE_WEBHOOK_SIGNATURE_KEY are server-side
# only. Set them as Cloudflare Worker secrets via the Cloudflare Dashboard
# or `wrangler secret put <NAME>`.

# ========== GOOGLE (public IDs) ==========
# OAuth Client ID is public by design (origin allowlist in Google Cloud).
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CALENDAR_ID=primary

# NOTE: Google client_secret, refresh_token, and Maps/Places API keys are
# server-side only (Cloudflare Worker secrets). If you want live Google
# reviews, wire a /api/google/places/details endpoint in the worker.

# ========== CLOUDFLARE WORKER ==========
# Public URL of the worker. Frontend calls this for every Square, Trainerize,
# and Google Meet operation; the worker adds credentials server-side.
VITE_WORKER_URL=

# ========== TRAINERIZE (public IDs) ==========
# Your trainer ID in Trainerize (so clients get assigned to you)
# Find in: Trainerize > Settings > Account
VITE_TRAINERIZE_COACH_USER_ID=

# Optional Zapier fallback — leave blank unless you're not using the worker.
VITE_TRAINERIZE_WEBHOOK_URL=

# ============================================
# WORKER-SIDE SECRETS (set via Cloudflare Dashboard, NOT here)
# ============================================
# Required:
#   SQUARE_ACCESS_TOKEN             — from Square Dashboard > Apps > OAuth
#   SQUARE_WEBHOOK_SIGNATURE_KEY    — from Square Dashboard > Webhooks
#   TRAINERIZE_API_KEY              — from api@trainerize.com
#   TRAINERIZE_TRAINER_GROUP_ID     — from api@trainerize.com
#   ADMIN_LOG_TOKEN                 — random string you pick, used by /logs
# Optional:
#   GOOGLE_CLIENT_SECRET            — OAuth client secret (for server flows)
#   GOOGLE_REFRESH_TOKEN            — for long-lived Calendar access
#   GOOGLE_MAPS_API_KEY             — if proxying Places API through worker
