# ============================================
# Alex's Fitness - Environment Variables
# Copy this file to .env and fill in your keys
# ============================================


# ========== SQUARE ==========
# Dashboard: https://developer.squareup.com/apps
# Used for: payments, catalog sync, bookings, calendar, team members, messaging

# Client-side payment form (Web Payments SDK)
VITE_SQUARE_APPLICATION_ID=

# Your business location ID (find in Square Dashboard > Locations)
VITE_SQUARE_LOCATION_ID=

# Server-side API access (Catalog, Bookings, Team, Customers)
# Get from: Square Dashboard > Apps > OAuth > Access Token
VITE_SQUARE_ACCESS_TOKEN=

# Service variation ID for booking appointments
# Get from: Square Dashboard > Appointments > Services
VITE_SQUARE_SERVICE_ID=


# ========== GOOGLE REVIEWS ==========
# Used for: daily auto-sync of Google reviews (5-star only shown on site)

# Find Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
VITE_GOOGLE_PLACE_ID=

# API key with Places API enabled
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=


# ========== GOOGLE MEET / CALENDAR ==========
# Used for: auto-creating Google Meet links for virtual consultations
# Enable: Google Calendar API at https://console.cloud.google.com/apis/library

# OAuth2 credentials (create at https://console.cloud.google.com/apis/credentials)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Refresh token for server-side token renewal
# Generate via OAuth2 playground or your auth flow
# Scopes needed: https://www.googleapis.com/auth/calendar.events
VITE_GOOGLE_REFRESH_TOKEN=

# API key for Calendar API calls
VITE_GOOGLE_API_KEY=

# Which Google Calendar to create events on (default: primary)
VITE_GOOGLE_CALENDAR_ID=primary
