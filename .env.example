# ============================================
# Alex's Fitness - Environment Variables
# Copy this file to .env and fill in your keys
# ============================================


# ========== SQUARE ==========
# Dashboard: https://developer.squareup.com/apps
# Used for: payments, catalog sync, bookings, calendar, team members, messaging

# Client-side payment form (Web Payments SDK)
VITE_SQUARE_APPLICATION_ID=

# Your business location ID (find in Square Dashboard > Locations)
VITE_SQUARE_LOCATION_ID=

# Server-side API access (Catalog, Bookings, Team, Customers)
# Get from: Square Dashboard > Apps > OAuth > Access Token
VITE_SQUARE_ACCESS_TOKEN=

# Service variation IDs (one per session type)
# Get from: Square API > Catalog > list items > variation IDs
VITE_SQUARE_SERVICE_CONSULTATION=
VITE_SQUARE_SERVICE_30MIN=
VITE_SQUARE_SERVICE_60MIN=


# ========== GOOGLE REVIEWS ==========
# Used for: daily auto-sync of Google reviews (5-star only shown on site)

# Find Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
VITE_GOOGLE_PLACE_ID=

# API key with Places API enabled
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=


# ========== GOOGLE MEET / CALENDAR ==========
# Used for: auto-creating Google Meet links for virtual consultations
# Enable: Google Calendar API at https://console.cloud.google.com/apis/library

# OAuth2 credentials (create at https://console.cloud.google.com/apis/credentials)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Refresh token for server-side token renewal
# Generate via OAuth2 playground or your auth flow
# Scopes needed: https://www.googleapis.com/auth/calendar.events
VITE_GOOGLE_REFRESH_TOKEN=

# API key for Calendar API calls
VITE_GOOGLE_API_KEY=

# Which Google Calendar to create events on (default: primary)
VITE_GOOGLE_CALENDAR_ID=primary


# ========== TRAINERIZE ==========
# Used for: syncing new clients, bookings, session credits, and payments to your Trainerize app
# API docs: https://developers.trainerize.com (password: tzAPI)
# API version: v03 (RPC-style, all POST endpoints)
# Auth: Basic base64(groupID:APIToken)
# Requires: Studio or Enterprise plan for direct API
#
# Two integration methods (use one or both):
#
# METHOD 1: Direct API (Studio/Enterprise plan)
# Contact api@trainerize.com to get your Group ID and API Token

# Your Trainerize Group ID (first part of Basic Auth)
VITE_TRAINERIZE_GROUP_ID=

# Your Trainerize API Token (second part of Basic Auth)
VITE_TRAINERIZE_API_KEY=

# API base URL (v03 — all endpoints are POST with JSON body)
VITE_TRAINERIZE_API_URL=https://api.trainerize.com/v03

# Your trainer ID in Trainerize (so clients get assigned to you)
# Find in: Trainerize > Settings > Account
VITE_TRAINERIZE_TRAINER_ID=

# METHOD 2: Webhook via Zapier (works on any Trainerize plan)
# Create a Zapier "Catch Hook" trigger and paste the webhook URL here
# Then set up Zap actions: Trainerize > Create Client, etc.
# Guide: https://help.trainerize.com/hc/en-us/articles/210270693

VITE_TRAINERIZE_WEBHOOK_URL=

# ========== SQUARE WEBHOOK (Recurring Payment → Trainerize Sync) ==========
# This runs as a Cloudflare Worker, NOT in the frontend
# See worker/webhook-handler.js for deployment instructions
#
# After deploying the worker, configure in Square Dashboard > Webhooks:
#   URL: https://your-worker.your-subdomain.workers.dev
#   Events: subscription.updated, payment.completed
#
# Worker secrets (set via: wrangler secret put <NAME>):
#   SQUARE_APPLICATION_ID
#   SQUARE_ACCESS_TOKEN
#   SQUARE_WEBHOOK_SIGNATURE_KEY  ← from Square Dashboard > Webhooks
#   TRAINERIZE_GROUP_ID           ← from api@trainerize.com
#   TRAINERIZE_API_KEY            ← from api@trainerize.com
#   TRAINERIZE_TRAINER_ID
